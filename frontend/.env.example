# All REACT_APP_* vars are embedded into the client bundle and are
# therefore PUBLIC — visible to anyone who loads the app. Only put
# public-safe values here. Never place server-side secrets (JWT secret,
# service-role keys, Stripe secret key, DB URL, etc.) in this file.

# Backend API base URL (leave as /api to use the same-origin proxy)
REACT_APP_API_URL="/api"

# ── PostHog (product analytics) ───────────────────────────
REACT_APP_POSTHOG_KEY="phc_your_posthog_key_here"

# ── Mapbox (Bible maps) — public token, restrict by URL in Mapbox ──
REACT_APP_MAPBOX_TOKEN="pk.your_public_mapbox_token"

# ── Metered TURN/STUN (WebRTC prayer-cell audio) ──────────
# These are exposed to the browser by necessity. Restrict/rotate them
# in the Metered dashboard; prefer short-lived credentials in future.
REACT_APP_TURN_USERNAME="your-turn-username"
REACT_APP_TURN_CREDENTIAL="your-turn-credential"
