generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime queries go through Supabase's TRANSACTION-mode pooler (port 6543,
  // ?pgbouncer=true&connection_limit=...). Transaction mode returns each
  // connection to the pool after every query/transaction, so a small pool of
  // real Postgres connections serves far more concurrent clients than session
  // mode (which pins a connection for the whole session — the cause of the
  // "max clients reached in session mode, pool_size: 15" exhaustion).
  url       = env("DATABASE_URL")
  // Migrations (prisma migrate deploy in the start script) and any DDL cannot
  // run through the transaction pooler — they need a direct/session connection.
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String
  bio             String?
  churchName      String?
  location        String?
  profilePhoto    String?
  coverPhoto      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  prayerStreak        Int       @default(0)
  longestPrayerStreak Int       @default(0)
  lastPrayerDate      DateTime?

  gratitudeStreak     Int       @default(0)
  lastGratitudeDate   DateTime?

  prayerRequests  PrayerRequest[]
  prayerSessions  PrayerSession[]
  posts           Post[]
  postLikes       PostLike[]
  comments        Comment[]
  notifications   Notification[]
  botMessages     BibleBotMessage[]
  resetTokens     PasswordResetToken[]
  churchFollows   ChurchFollow[]

  latitude              Float?
  longitude             Float?

  dailyPrayerQuota      Int       @default(5)
  prayerWarriorBadge    Boolean   @default(false)
  totalPeoplesPrayedFor Int       @default(0)
  prayerWarriorEarnedAt DateTime?

  graceDaysAvailable    Int       @default(0)
  graceDayUsedAt        DateTime?

  isVerifiedPastor  Boolean  @default(false)
  pastorBio         String?
  pastorChurch      String?
  pastorTitle       String?

  isAdmin           Boolean  @default(false)
  isSuspended       Boolean  @default(false)

  followers       Follow[]  @relation("Following")
  following       Follow[]  @relation("Followers")
  dailyQuotaLogs  DailyQuotaLog[]
  prayerDraft     PrayerDraft?
  conversationParticipants ConversationParticipant[]
  sentMessages    Message[]
  confessionAuthors ConfessionAuthor[]
  confessionEncouragements ConfessionEncouragement[]
  confessionComments ConfessionComment[]
  pastorRequests  PastorPrayerRequest[] @relation("PastorRequests")
  userPastorRequests PastorPrayerRequest[] @relation("UserPastorRequests")
  prayerPastorAccess PrayerPastorAccess[]

  notifyPrayerStarted  Boolean @default(true)
  notifyNewFollower    Boolean @default(true)
  notifyPostLike       Boolean @default(true)
  notifyPostComment    Boolean @default(true)
  notifyPrayerAnswered    Boolean @default(true)
  notifyConfessionComment Boolean @default(true)
  notifyStreakReminder    Boolean @default(true)
  notifyPartnerActivity   Boolean @default(true)

  prayerReminderEnabled Boolean @default(false)
  prayerReminderTime    String?

  autoDownloadMedia     Boolean @default(true)

  prayerCellsCreated              PrayerCell[]                   @relation("PrayerCellCreator")
  prayerCellMemberships           PrayerCellMember[]             @relation("PrayerCellMemberships")
  prayerCellJoinRequests          PrayerCellJoinRequest[]        @relation("PrayerCellJoinRequests")
  prayerCellSessionsStarted       PrayerCellSession[]            @relation("PrayerCellSessionStarter")
  prayerCellSessionParticipations PrayerCellSessionParticipant[] @relation("PrayerCellSessionParticipations")

  gender          String?

  partnerships1   PrayerPartnership[] @relation("User1Partnerships")
  partnerships2   PrayerPartnership[] @relation("User2Partnerships")
  partnerRequests PrayerPartnerRequest[]
  gratitudeEntries GratitudeEntry[]

  reportsMade     Report[]
  blocksInitiated Block[] @relation("Blocker")
  blocksReceived  Block[] @relation("Blocked")

  @@map("users")
}

// A user-submitted report against a piece of content. reportedUserId is a plain
// id (not a relation) — for confessions it is populated only via deliberate
// admin lookup through ConfessionAuthor, never surfaced to reporters.
model Report {
  id             String    @id @default(cuid())
  reporterId     String
  reporter       User      @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason         String    // SPAM | HARASSMENT | HATE_SPEECH | SEXUAL_CONTENT | VIOLENCE | SELF_HARM | MISINFORMATION | OTHER
  details        String?
  contentType    String    // PRAYER | CONFESSION | COMMENT | MESSAGE | PROFILE | PRAYER_CELL
  contentId      String
  reportedUserId String?
  status         String    @default("PENDING") // PENDING | REVIEWED | ACTIONED | DISMISSED
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  @@index([status])
  @@index([reporterId, contentType, contentId])
  @@map("reports")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

// A persistent group community (like a church small group) that can also host
// live audio prayer sessions. Was previously a transient 1-host live room.
model PrayerCell {
  id            String    @id @default(cuid())
  name          String
  description   String?
  imageUrl      String?
  creatorId     String
  creator       User      @relation("PrayerCellCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  joinPolicy    String    @default("open") // "open" | "request"
  totalSessions Int       @default(0)
  totalMinutes  Int       @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())

  members      PrayerCellMember[]
  joinRequests PrayerCellJoinRequest[]
  sessions     PrayerCellSession[]

  @@index([creatorId])
  @@map("prayer_cells")
}

// Membership + role. The creator is auto-added as admin on cell creation.
model PrayerCellMember {
  id       String     @id @default(cuid())
  cellId   String
  userId   String
  role     String     @default("member") // "admin" | "member"
  joinedAt DateTime   @default(now())
  cell     PrayerCell @relation(fields: [cellId], references: [id], onDelete: Cascade)
  user     User       @relation("PrayerCellMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cellId, userId])
  @@index([userId])
  @@map("prayer_cell_members")
}

// A pending/approved/denied request to join a "request"-policy cell.
model PrayerCellJoinRequest {
  id        String     @id @default(cuid())
  cellId    String
  userId    String
  status    String     @default("pending") // "pending" | "approved" | "denied"
  createdAt DateTime   @default(now())
  cell      PrayerCell @relation(fields: [cellId], references: [id], onDelete: Cascade)
  user      User       @relation("PrayerCellJoinRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cellId, userId])
  @@index([cellId, status])
  @@map("prayer_cell_join_requests")
}

// A live audio prayer session belonging to a cell. Multiple members can join.
model PrayerCellSession {
  id           String     @id @default(cuid())
  cellId       String
  startedById  String
  startedAt    DateTime   @default(now())
  endedAt      DateTime?
  isActive     Boolean    @default(true)
  cell         PrayerCell @relation(fields: [cellId], references: [id], onDelete: Cascade)
  startedBy    User       @relation("PrayerCellSessionStarter", fields: [startedById], references: [id], onDelete: Cascade)
  participants PrayerCellSessionParticipant[]

  @@index([cellId])
  @@map("prayer_cell_sessions")
}

model PrayerCellSessionParticipant {
  id        String            @id @default(cuid())
  sessionId String
  userId    String
  joinedAt  DateTime          @default(now())
  leftAt    DateTime?
  session   PrayerCellSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User              @relation("PrayerCellSessionParticipations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("prayer_cell_session_participants")
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  theme                  String  @default("light")
  vanishMode             String  @default("off") // off | after_seen | 24h | 7d | 30d
  readReceiptsEnabled    Boolean @default(true)
  typingIndicatorEnabled Boolean @default(true)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  reaction       String?
  audioUrl       String?
  audioDuration  Int?
  imageUrl       String?
  replyToId      String?
  isDeleted      Boolean      @default(false)
  isRemoved      Boolean      @default(false)
  removedReason  String?
  isVanish       Boolean      @default(false)
  seenAt         DateTime?
  expiresAt      DateTime?
  sharedPrayerRequestId String?
  createdAt      DateTime     @default(now())
  isRead         Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]    @relation("MessageReplies")
  @@map("messages")
}

model Confession {
  id             String    @id @default(cuid())
  content        String
  category       String    @default("General")
  createdAt      DateTime  @default(now())
  isRemoved      Boolean   @default(false)
  removedReason  String?
  encouragements ConfessionEncouragement[]
  comments       ConfessionComment[]
  @@map("confessions")
}

// Authorship lives ONLY here, in its own table, and is never joined into
// any public confession query. The only read path is GET /confessions/mine,
// filtered to the requester's own session.
model ConfessionAuthor {
  id           String   @id @default(cuid())
  confessionId String   @unique
  userId       String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("confession_authors")
}

model ConfessionEncouragement {
  id           String     @id @default(cuid())
  confessionId String
  userId       String
  confession   Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([confessionId, userId])
  @@map("confession_encouragements")
}

model ConfessionComment {
  id           String     @id @default(cuid())
  confessionId String
  userId       String
  content      String
  isAnonymous  Boolean    @default(false)
  isRemoved    Boolean    @default(false)
  removedReason String?
  createdAt    DateTime   @default(now())
  confession   Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("confession_comments")
}

model PastorPrayerRequest {
  id          String   @id @default(cuid())
  userId      String
  pastorId    String
  request     String
  isAnonymous Boolean  @default(false)
  status      String   @default("PENDING")
  response    String?
  createdAt   DateTime @default(now())
  respondedAt DateTime?
  user        User     @relation("UserPastorRequests", fields: [userId], references: [id], onDelete: Cascade)
  pastor      User     @relation("PastorRequests", fields: [pastorId], references: [id], onDelete: Cascade)
  @@map("pastor_prayer_requests")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model PrayerRequest {
  id                String          @id @default(cuid())
  userId            String
  title             String
  body              String
  isActive          Boolean         @default(true)
  isAnswered        Boolean         @default(false)
  answeredAt        DateTime?
  testimonyMessage  String?
  answeredIsPublic  Boolean         @default(true)
  isRemoved         Boolean         @default(false)
  removedReason     String?
  updateMessage     String?
  category          PrayerCategory  @default(GENERAL)
  isUrgent          Boolean         @default(false)
  visibility        String          @default("PUBLIC")
  isAnonymous       Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  lastActivityAt    DateTime        @default(now())

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions          PrayerSession[]
  pastorAccess      PrayerPastorAccess[]

  @@map("prayer_requests")
}

model PrayerPastorAccess {
  id              String        @id @default(cuid())
  prayerRequestId String
  pastorId        String
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  pastor          User          @relation(fields: [pastorId], references: [id], onDelete: Cascade)
  @@unique([prayerRequestId, pastorId])
  @@map("prayer_pastor_access")
}

model PrayerSession {
  id              String    @id @default(cuid())
  userId          String
  prayerRequestId String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int?

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)

  @@map("prayer_sessions")
}

model Post {
  id          String     @id @default(cuid())
  userId      String
  content     String
  type        PostType   @default(UPDATE)
  bibleVerse  String?
  location    String?
  isArchived  Boolean    @default(false)
  media       PostMedia[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes       PostLike[]
  comments    Comment[]

  @@map("posts")
}

model PostMedia {
  id        String    @id @default(cuid())
  postId    String
  url       String
  type      MediaType
  order     Int       @default(0)

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_media")
}

enum PrayerCategory {
  GENERAL
  HEALTH
  FAMILY
  CAREER
  FINANCIAL
  RELATIONSHIP
  SPIRITUAL
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PostType {
  UPDATE
  TESTIMONY
  VERSE
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("post_likes")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  fromUser  String?
  refId     String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  PRAYER_STARTED
  NEW_FOLLOWER
  POST_LIKE
  POST_COMMENT
  CHURCH_POST
  NEW_MESSAGE
  PRAYER_PARTNER_MATCHED
  SOMEONE_PRAYED
  PRAYER_ANSWERED
  CONFESSION_COMMENT
  STREAK_AT_RISK
  PARTNER_SHARED_PRAYER
  REQUEST_NEEDS_BUMP
}

model Church {
  id          String   @id @default(cuid())
  name        String
  description String?
  location    String?
  website     String?
  logo        String?
  coverPhoto  String?
  adminId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  followers   ChurchFollow[]
  posts       ChurchPost[]

  @@map("churches")
}

model ChurchFollow {
  id        String   @id @default(cuid())
  userId    String
  churchId  String
  createdAt DateTime @default(now())

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  church    Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([userId, churchId])
  @@map("church_follows")
}

model ChurchPost {
  id        String   @id @default(cuid())
  churchId  String
  title     String?
  content   String
  type      ChurchPostType @default(UPDATE)
  imageUrl  String?
  eventDate DateTime?
  createdAt DateTime @default(now())

  church    Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@map("church_posts")
}

enum ChurchPostType {
  UPDATE
  EVENT
  SERVICE
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model BibleBotMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bible_bot_messages")
}

model PrayerDraft {
  id         String   @id @default(cuid())
  userId     String   @unique
  title      String   @default("")
  body       String   @default("")
  category   String   @default("GENERAL")
  visibility String   @default("PUBLIC")
  isUrgent   Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("prayer_drafts")
}

model PrayerPartnership {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  status    String   @default("ACTIVE")
  startedAt DateTime @default(now())
  expiresAt DateTime
  user1     User     @relation("User1Partnerships", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User     @relation("User2Partnerships", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
  @@map("prayer_partnerships")
}

model PrayerPartnerRequest {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("WAITING")
  gender    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("prayer_partner_requests")
}

model DailyQuotaLog {
  id         String   @id @default(cuid())
  userId     String
  date       String
  target     Int
  completed  Int      @default(0)
  isComplete Boolean  @default(false)

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_quota_logs")
}

model GratitudeEntry {
  id        String   @id @default(cuid())
  userId    String
  content   String
  mood      String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gratitude_entries")
}
