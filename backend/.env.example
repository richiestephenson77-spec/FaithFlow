# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string (Supabase). Never commit the real value.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# ── Auth ──────────────────────────────────────────────────
# Long random string used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="generate-a-long-random-secret"

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Frontend origin allowed by CORS
CLIENT_URL="http://localhost:3000"

# ── Anthropic (Bible bot) ─────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Google Places (church/location search) ────────────────
GOOGLE_PLACES_KEY="your-google-places-api-key"

# ── Resend (transactional email) ──────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="FaithBridge <onboarding@resend.dev>"

# ── Cloudinary (image uploads) ────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
